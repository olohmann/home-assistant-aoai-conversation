# Local smoketest configuration for the Azure OpenAI Conversation integration.
#
# Copy this file to `.env` (which is git-ignored) and fill in your values, then run:
#   uv run python scripts/smoketest.py    (or:  mise run smoketest)
#
# The smoketest never commits or prints secrets.

# --- LLM: Azure OpenAI (conversation / AI Task) ---
# Resource endpoint, e.g. https://your-resource.services.ai.azure.com/
AOAI_LLM_ENDPOINT=
AOAI_LLM_API_KEY=
# Your chat model *deployment* name.
AOAI_LLM_CHAT_MODEL=gpt-4.1-mini

# --- Azure AI Speech (STT + TTS) ---
# With a multi-service Azure AI Foundry resource this is the SAME key as the LLM,
# but a different endpoint host, e.g.
#   https://your-resource.cognitiveservices.azure.com/
AOAI_SPEECH_ENDPOINT=
AOAI_SPEECH_API_KEY=

# STT options
AOAI_STT_LANGUAGE=de-DE

# TTS options
AOAI_TTS_VOICE=de-DE-KatjaNeural
AOAI_TTS_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3

# --- Optional per-service overrides ---
# By default STT and TTS use AOAI_SPEECH_ENDPOINT / AOAI_SPEECH_API_KEY. Set these
# only if your STT or TTS endpoint/key differ (e.g. separate Speech resources).
# AOAI_STT_ENDPOINT=
# AOAI_STT_API_KEY=
# AOAI_TTS_ENDPOINT=
# AOAI_TTS_API_KEY=

# Phrase used for the TTS + STT round-trip check.
AOAI_SMOKETEST_PHRASE=Schalte das Licht im Wohnzimmer ein.

# --- Optional: Microsoft Foundry Agent (conversation agent mode) ---
# Set these to test calling a persistent Foundry agent via the Responses API.
# The project endpoint is the one from the Foundry welcome screen, e.g.
#   https://your-resource.services.ai.azure.com/api/projects/your-project
# AOAI_AGENT_ENDPOINT=
# AOAI_AGENT_NAME=
# AOAI_AGENT_VERSION=
# AOAI_AGENT_API_KEY=   # defaults to AOAI_LLM_API_KEY

